{{!
    @template tool_bulkcleaning/docs

    Markdown documentation viewer.

    Example context (json):
    {
        "contentjson": "{}",
        "lang": "es",
        "page": "README",
        "topbartitle": "Limpieza masiva - Documentación",
        "readmeurl": "?lang=es&page=README",
        "langs": [
            {"code": "en", "label": "EN", "selected": false},
            {"code": "es", "label": "ES", "selected": true}
        ],
        "tplmode": true
    }
}}

<div class="tool-bulkcleaning-docs">
    <div class="docs-topbar d-flex align-items-center justify-content-between p-2 mb-3 rounded bg-primary text-white">
        <a href="{{{readmeurl}}}" class="text-white font-weight-bold" style="text-decoration:none;">{{topbartitle}}</a>
        <select class="form-control form-control-sm" style="width:auto;" onchange="location.href='?lang='+this.value+'&page={{page}}'">
            {{#langs}}
                <option value="{{code}}" {{#selected}}selected{{/selected}}>{{label}}</option>
            {{/langs}}
        </select>
    </div>
    <div class="docs-content card">
        <div class="card-body" id="docs-content"></div>
    </div>
</div>

{{^tplmode}}
{{#js}}
require(['jquery'], function($) {
    var raw = {{{contentjson}}};
    var decoded = new DOMParser().parseFromString(raw, 'text/html').body.textContent;
    $('#docs-content').html(marked.parse(decoded));
});
{{/js}}
{{/tplmode}}
